<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Neon Glow (Soft Shadow Base) -->
    <item android:top="8dp" android:left="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#26B8FD4B" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#001a1919" />
        </shape>
    </item>

    <!-- Glass Gradient with Primary Tint -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:type="linear"
                android:angle="225"
                android:startColor="#B3262626"
                android:endColor="#661a1919" />
        </shape>
    </item>

    <!-- Primary Accent Outline -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#1A494847" />
        </shape>
    </item>
</layer-list>
