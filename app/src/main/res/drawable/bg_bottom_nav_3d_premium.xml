<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom Drop Shadow / Base Rim -->
    <item android:top="2dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="36dp" />
            <solid android:color="#E5E5EA" />
        </shape>
    </item>
    
    <!-- Outer Glass Frosted Rim -->
    <item android:bottom="4dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="36dp" />
            <solid android:color="#F2F2F7" />
        </shape>
    </item>
    
    <!-- Top Frosted Face (Inset to give 3D bevel look) -->
    <item android:bottom="6dp" android:top="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="34dp" />
            <solid android:color="#FFFFFF" />
            <!-- Soft inner top highlight edge to simulate glass reflection -->
            <stroke android:width="0.5dp" android:color="#80FBFBFD" />
        </shape>
    </item>
    
    <!-- Inner High-glow rim -->
    <item android:bottom="7dp" android:top="1dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="33dp" />
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>
