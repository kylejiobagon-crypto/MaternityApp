<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom Cast Shadow for 3D Floating Effect -->
    <item android:top="8dp" android:left="8dp" android:right="8dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="44dp" />
            <solid android:color="#26000000" />
        </shape>
    </item>

    <!-- Main Floating Body (Glassmorphic White) -->
    <item android:bottom="10dp" android:left="4dp" android:right="4dp">
         <shape android:shape="rectangle">
             <gradient
                 android:startColor="#F2FFFFFF"
                 android:endColor="#E6F8FAFF"
                 android:angle="135" />
             <corners android:radius="44dp" />
         </shape>
    </item>

    <!-- 3D Bevel Rim Light -->
    <item android:bottom="10dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <stroke android:width="1.8dp" android:color="#FFFFFFFF" />
            <corners android:radius="44dp" />
        </shape>
    </item>

    <!-- Inner Shadow for Depth -->
    <item android:bottom="10dp" android:left="4dp" android:right="4dp">
         <shape android:shape="rectangle">
             <gradient
                 android:startColor="#0D000000"
                 android:endColor="#00000000"
                 android:angle="90" />
             <corners android:radius="44dp" />
         </shape>
    </item>
</layer-list>
