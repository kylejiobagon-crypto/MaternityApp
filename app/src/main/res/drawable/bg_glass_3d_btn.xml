<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- OUTER SHADOW -->
    <item>
        <shape>
            <corners android:radius="35dp" />
            <solid android:color="#301A5276" />
            <padding android:bottom="8dp" android:right="4dp" />
        </shape>
    </item>
    
    <!-- GLASS BODY -->
    <item>
        <shape>
            <corners android:radius="35dp" />
            <gradient
                android:startColor="#CC5DADE2"
                android:centerColor="#CC1A5276"
                android:endColor="#CC154360"
                android:angle="270" />
            <stroke
                android:width="2dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>
    
    <!-- REFRACTION/HIGHLIGHT -->
    <item android:bottom="10dp" android:left="5dp" android:right="5dp" android:top="2dp">
        <shape>
            <corners android:radius="35dp" />
            <stroke
                android:width="1dp"
                android:color="#80FFFFFF" />
        </shape>
    </item>
</layer-list>
