<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Ambient Base (Semi-transparent black) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#991a1919" />
        </shape>
    </item>

    <!-- Glass Gradient (135deg Dark Grey) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:type="linear"
                android:angle="225"
                android:startColor="#B3262626"
                android:endColor="#661a1919" />
        </shape>
    </item>

    <!-- Super Fine Pixel Rim (Outline-Variant) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#1A494847" />
        </shape>
    </item>
</layer-list>
