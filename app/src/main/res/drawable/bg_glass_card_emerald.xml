<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/billing_glass_bg_start"
                android:endColor="@color/billing_glass_bg_end"
                android:angle="135" />
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_emerald_stroke" />
        </shape>
    </item>
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_emerald_highlight" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
