<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom Shadow / Depth Layer -->
    <item android:top="3dp" android:left="1dp" android:right="1dp" android:bottom="-3dp">
        <shape android:shape="rectangle">
            <solid android:color="#0D000000" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Main Container Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="24dp" />
            <stroke android:width="1.2dp" android:color="#F3F4FB" />
        </shape>
    </item>

    <!-- Inner Rim Light Shade (Top highlight) -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FDFDFF"
                android:endColor="#FFFFFF"
                android:angle="270" />
            <corners android:radius="23dp" />
        </shape>
    </item>

    <!-- Subtle Glass Finish (Soft Gradient) -->
    <item android:top="6dp" android:left="6dp" android:right="6dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#05F8FAFF"
                android:endColor="#0A007AFF"
                android:angle="45" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</layer-list>
