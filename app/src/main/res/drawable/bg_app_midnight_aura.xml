<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- DEEP SPACE BASE -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#020617" />
        </shape>
    </item>

    <!-- BLOOM 1: TOP LEFT CYAN GLOW -->
    <item android:top="-200dp" android:left="-150dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="800dp"
                android:centerX="0.0"
                android:centerY="0.0"
                android:startColor="#2000FBFB"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- BLOOM 2: CENTER RIGHT VIOLET GLOW -->
    <item android:top="200dp" android:right="-200dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:centerX="1.0"
                android:centerY="0.5"
                android:startColor="#26CC00FF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- BLOOM 3: BOTTOM LEFT GREEN GLOW -->
    <item android:bottom="-200dp" android:left="-200dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="700dp"
                android:centerX="0.0"
                android:centerY="1.0"
                android:startColor="#1A34C759"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- BLOOM 4: BOTTOM RIGHT PINK GLOW -->
    <item android:bottom="-150dp" android:right="-250dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:centerX="1.0"
                android:centerY="1.0"
                android:startColor="#1FFF2D55"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- NOISE / DUST (Subtle Overlay) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#0DFFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
