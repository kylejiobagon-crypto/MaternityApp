<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Blue Glow Under-shadow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D0071E3" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <!-- Cyan-Sky Gradient Surface -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#EBF5FF"
                android:centerColor="#F0F8FF"
                android:endColor="#FFFFFF"
                android:angle="135" />
            <corners android:radius="14dp" />
            <stroke android:width="2.5dp" android:color="#0071E3" />
        </shape>
    </item>
</layer-list>
