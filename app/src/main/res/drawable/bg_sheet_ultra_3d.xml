<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#080A10" />
            <corners android:topLeftRadius="36dp" android:topRightRadius="36dp" />
        </shape>
    </item>
    <!-- Top inner glow/reflection to look 3D glass -->
    <item android:top="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#0C101A" />
            <corners android:topLeftRadius="36dp" android:topRightRadius="36dp" />
            <stroke android:width="1dp" android:color="#1A2235" />
        </shape>
    </item>
    <!-- Secondary base -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#0F131E" />
            <corners android:topLeftRadius="34dp" android:topRightRadius="34dp" />
        </shape>
    </item>
</layer-list>
