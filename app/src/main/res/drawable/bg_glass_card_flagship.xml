<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main glass background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#14FFFFFF"
                android:endColor="#05FFFFFF"
                android:angle="135" />
            <corners android:radius="32dp" />
            <stroke
                android:width="1dp"
                android:color="#5900F2FF" /> <!-- 35% Opacity Cyan -->
        </shape>
    </item>
    
    <!-- Inner top highlight -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="40dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#2600F2FF"
                android:endColor="@android:color/transparent"
                android:angle="90" />
            <corners android:radius="32dp" />
        </shape>
    </item>
</layer-list>
