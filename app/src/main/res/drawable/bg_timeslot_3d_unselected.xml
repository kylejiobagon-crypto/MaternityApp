<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow / Bevel effect underneath -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#05070A" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Top reflection / Bevel -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#21293B" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Actual Surface -->
    <item android:top="1dp" android:bottom="4dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#151A26" />
            <corners android:radius="15dp" />
        </shape>
    </item>
</layer-list>
