<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:bottom="4dp" android:right="4dp">
        <shape>
            <corners android:radius="32dp" />
            <solid android:color="#20000000" />
        </shape>
    </item>
    <item android:bottom="6dp" android:right="6dp">
        <shape>
            <gradient
                android:startColor="#06B6D4"
                android:centerColor="#0891B2"
                android:endColor="#0E7490"
                android:angle="135" />
            <corners android:radius="32dp" />
            <stroke android:width="1.5dp" android:color="#40FFFFFF" />
        </shape>
    </item>
    <item android:bottom="50dp" android:left="8dp" android:right="8dp" android:top="2dp">
        <shape>
            <gradient android:startColor="#60FFFFFF" android:endColor="#00FFFFFF" android:angle="270" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
