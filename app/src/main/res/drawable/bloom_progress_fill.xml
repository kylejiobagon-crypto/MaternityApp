<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Progress Track Fill -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00AFFE"
                android:centerColor="#6366F1"
                android:endColor="#8B5CF6" />
        </shape>
    </item>

    <!-- Top Glow (Specularity) -->
    <item android:bottom="8dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#66FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <!-- Core Inner Shadow (For depth) -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
</layer-list>
