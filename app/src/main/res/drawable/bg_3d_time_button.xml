<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- SELECTED (ACTIVE/CLICKABLE) -->
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape>
                    <corners android:radius="12dp" />
                    <solid android:color="#201A5276" />
                </shape>
            </item>
            <item android:bottom="4dp" android:right="2dp">
                <shape>
                    <corners android:radius="12dp" />
                    <solid android:color="#401A5276" />
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp">
                <shape>
                    <corners android:radius="12dp" />
                    <solid android:color="#5DADE2" />
                    <stroke
                        android:width="2dp"
                        android:color="#FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- DEFAULT (UNSELECTED) -->
    <item>
        <layer-list>
            <item>
                <shape>
                    <corners android:radius="12dp" />
                    <solid android:color="#0D000000" />
                </shape>
            </item>
            <item android:bottom="4dp" android:right="2dp">
                <shape>
                    <corners android:radius="12dp" />
                    <solid android:color="#1A000000" />
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp">
                <shape>
                    <corners android:radius="12dp" />
                    <solid android:color="#FFFFFF" />
                    <stroke
                        android:width="1dp"
                        android:color="#0D000000" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
