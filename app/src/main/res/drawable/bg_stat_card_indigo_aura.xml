<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep Indigo Foundation -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1E1B4B"
                android:centerColor="#312E81"
                android:endColor="#3730A3"
                android:angle="0" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Inner-Glow (Top-Left Edge Shine) -->
    <item android:bottom="80dp" android:right="50dp">
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.0"
                android:centerY="0.0"
                android:gradientRadius="100dp"
                android:startColor="#33FFFFFF" 
                android:endColor="#00FFFFFF" 
                android:type="radial" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Glossy Rim Highlight -->
    <item android:bottom="4dp" android:right="2dp" android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke android:width="1.2dp" android:color="#33FFFFFF" />
        </shape>
    </item>
</layer-list>
