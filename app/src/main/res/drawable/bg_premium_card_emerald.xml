<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep Outer Shadow -->
    <item android:bottom="4dp" android:right="4dp">
        <shape>
            <corners android:radius="32dp" />
            <solid android:color="#20000000" />
        </shape>
    </item>

    <!-- Main Emerald Gradient -->
    <item android:bottom="6dp" android:right="6dp">
        <shape>
            <gradient
                android:startColor="#10B981"
                android:centerColor="#059669"
                android:endColor="#047857"
                android:angle="135" />
            <corners android:radius="32dp" />
            <stroke android:width="1.5dp" android:color="#40FFFFFF" />
        </shape>
    </item>

    <!-- Top Gloss Reflection -->
    <item android:bottom="50dp" android:left="8dp" android:right="8dp" android:top="2dp">
        <shape>
            <gradient
                android:startColor="#60FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
