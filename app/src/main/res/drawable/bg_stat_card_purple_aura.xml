<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Ambient Shadow (Matching Purple) -->
    <item>
        <shape android:shape="rectangle">
            <padding android:bottom="8dp" android:left="4dp" android:right="4dp" android:top="4dp" />
            <solid android:color="#268B5CF6" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Purple Amethyst Glass Foundation -->
    <item android:bottom="4dp" android:right="2dp" android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#8B5CF6"
                android:centerColor="#7C3AED"
                android:endColor="#6D28D9"
                android:angle="0" />
            <corners android:radius="24dp" />
            <stroke android:width="1.2dp" android:color="#4DFFFFFF" />
        </shape>
    </item>

    <!-- Ambient Shadow Center Glow -->
    <item android:bottom="40dp" android:right="20dp" android:top="20dp" android:left="20dp">
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.5"
                android:centerY="0.5"
                android:gradientRadius="60dp"
                android:startColor="#33FFFFFF" 
                android:endColor="#00000000" 
                android:type="radial" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>
