<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- BROAD OVERLAY SHADOW -->
    <item>
        <shape>
            <corners android:topLeftRadius="36dp" android:topRightRadius="36dp" />
            <solid android:color="#20000000" />
            <padding android:top="8dp" />
        </shape>
    </item>
    
    <!-- GLASS BODY (GLASSMORPHISM EFFECT) -->
    <item>
        <shape>
            <corners android:topLeftRadius="36dp" android:topRightRadius="36dp" />
            <gradient
                android:startColor="#E6FDFBF7" 
                android:centerColor="#D9FFFFFF"
                android:endColor="#F4F6F7"
                android:angle="270" />
            <stroke
                android:width="2dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>
    
    <!-- TOP DRAG HANDLE TINT/RIM LIGHT -->
    <item android:bottom="20dp" android:left="30dp" android:right="30dp" android:top="2dp">
        <shape>
            <corners android:topLeftRadius="36dp" android:topRightRadius="36dp" />
            <stroke
                android:width="1dp"
                android:color="#60FFFFFF" />
        </shape>
    </item>
</layer-list>
