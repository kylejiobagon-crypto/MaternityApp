<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- OUTER SOFT SHADOW -->
    <item>
        <shape>
            <corners android:radius="28dp" />
            <solid android:color="#08000000" />
            <padding android:bottom="4dp" android:right="2dp" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="28dp" />
            <solid android:color="#12000000" />
            <padding android:bottom="2dp" android:right="1dp" />
        </shape>
    </item>
    
    <!-- THE MAIN BODY -->
    <item>
        <shape>
            <corners android:radius="28dp" />
            <gradient
                android:startColor="#FFFFFF"
                android:endColor="#F4F6F7"
                android:angle="270" />
            <stroke
                android:width="1dp"
                android:color="#15FFFFFF" />
        </shape>
    </item>
    
    <!-- TOP HIGHLIGHT (FOR 3D FEEL) -->
    <item android:bottom="2dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape>
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>
</layer-list>
