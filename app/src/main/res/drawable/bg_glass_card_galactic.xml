<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. MULTI-POINT AMBIENT GLOW (Simulating Depth/Zero-G Float) -->
    <!-- Bottom Purple Glow -->
    <item>
        <shape android:shape="rectangle">
            <padding android:bottom="8dp" android:left="6dp" android:right="6dp" android:top="2dp" />
            <solid android:color="#334200FF" /> <!-- rgba(66, 0, 255, 0.2) approx -->
            <corners android:radius="32dp" />
        </shape>
    </item>

    <!-- Side Cyan Glow -->
    <item>
        <shape android:shape="rectangle">
            <padding android:bottom="2dp" android:left="4dp" android:right="4dp" android:top="2dp" />
            <solid android:color="#1A00F2FF" /> <!-- rgba(0, 242, 255, 0.1) -->
            <corners android:radius="30dp" />
        </shape>
    </item>

    <!-- 2. FROSTED GLASS SURFACE -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#5919233C" /> <!-- rgba(25, 35, 60, 0.35) -->
            <corners android:radius="28dp" />
            <!-- 1px ELECTRIC CYAN GLOW RIM -->
            <stroke android:width="1.2dp" android:color="#00F2FF" /> 
        </shape>
    </item>

    <!-- 3. TOP-INNER LIGHTNING/SHEEN -->
    <item android:top="1.2dp" android:left="1.2dp" android:right="1.2dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#1AFFFFFF"
                android:endColor="#00000000" />
            <corners android:radius="27dp" />
        </shape>
    </item>
</layer-list>
