<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep Indigo Shadow (Depth Layer) -->
    <item android:top="10dp" android:left="10dp">
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <solid android:color="#204F46E5" />
        </shape>
    </item>

    <!-- Royal Silk Foundation -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <gradient
                android:type="linear"
                android:angle="225"
                android:startColor="#EEF2FF"
                android:centerColor="#E0E7FF"
                android:endColor="#D6DDFC" />
        </shape>
    </item>

    <!-- Frost Mesh Glow (Layer 2) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="180dp"
                android:centerX="0.2"
                android:centerY="0.2"
                android:startColor="#20FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Diamond Rim Detail -->
    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <stroke android:width="1dp" android:color="#99FFFFFF" />
        </shape>
    </item>

    <!-- Indigo Inner Depth Stroke -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <stroke android:width="2dp" android:color="#0D4F46E5" />
        </shape>
    </item>
</layer-list>
