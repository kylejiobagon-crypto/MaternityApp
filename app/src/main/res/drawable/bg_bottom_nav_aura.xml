<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow (Soft Violet Shadow) -->
    <item>
        <shape android:shape="rectangle">
            <padding android:bottom="10dp" android:left="10dp" android:right="10dp" android:top="10dp" />
            <solid android:color="#208B5CF6" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <!-- Frosted Glass Surface (Floating 10dp above screen bottom handled in XML padding/margin) -->
    <item android:bottom="8dp" android:right="4dp" android:top="4dp" android:left="4dp">
        <shape android:shape="rectangle">
            <!-- Frosted finish (alpha 0.95) -->
            <solid android:color="#F2FFFFFF" /> 
            <corners android:radius="30dp" />
            <stroke android:width="1.5dp" android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Glowing Rim Highlight -->
    <item android:bottom="50dp" android:right="20dp" android:top="8dp" android:left="20dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#4DFFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="15dp" />
        </shape>
    </item>
</layer-list>
