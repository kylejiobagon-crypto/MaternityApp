<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Shadow Layer (Bottom/Right) -->
    <item android:top="4dp" android:left="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#0D000000" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    
    <!-- Main Body Layer -->
    <item android:bottom="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFFFFF"
                android:centerColor="#F9FAFB"
                android:endColor="#F3F4F6"
                android:angle="135" />
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="#E5E7EB" />
        </shape>
    </item>

    <!-- Inner Reflection (Top/Left) -->
    <item android:bottom="8dp" android:right="8dp" android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="135" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</layer-list>
