<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. GLASS FILL (About 12% White) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#20FFFFFF" />
            <corners android:radius="40dp" />
        </shape>
    </item>

    <!-- 2. NEON STROKE ENHANCEMENT (Subtle Cyan Rim) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="40dp" />
            <stroke android:width="1dp" android:color="#4000FFFF" />
        </shape>
    </item>

    <!-- 3. TOP GLOSS -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="25dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#1AFFFFFF"
                android:endColor="#00000000" />
            <corners android:radius="39dp" />
        </shape>
    </item>
</layer-list>
