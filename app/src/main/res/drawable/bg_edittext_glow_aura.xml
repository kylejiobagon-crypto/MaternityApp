<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state: Neon Cyan Box Shadow Glow -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Cyan Halo Glow (15px equivalent) -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#4D00FFFF" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <item android:bottom="4dp" android:right="4dp" android:top="4dp" android:left="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#F9FAFB" />
                    <corners android:radius="12dp" />
                    <stroke android:width="2dp" android:color="#00FFFF" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- ENABLED (Edit Mode) but NOT Focused: Subtle Indigo-Cyan Tint to cue user -->
    <item android:state_enabled="true">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="14dp" />
            <stroke android:width="1.8dp" android:color="#60A5FA" /> 
        </shape>
    </item>

    <!-- Normal/Disabled state: Frosted Glass Finish -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F9FAFB" />
            <corners android:radius="14dp" />
            <stroke android:width="1.2dp" android:color="#E5E7EB" />
        </shape>
    </item>
</selector>
