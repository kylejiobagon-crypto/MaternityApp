<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- BROAD SOFT SHADOW -->
    <item>
        <shape>
            <corners android:radius="32dp" />
            <solid android:color="#301A5276" />
            <padding android:bottom="8dp" android:right="4dp" />
        </shape>
    </item>
    
    <!-- MAIN BUTTON BODY -->
    <item>
        <shape>
            <corners android:radius="32dp" />
            <gradient
                android:startColor="#1A5276"
                android:endColor="#154360"
                android:angle="270" />
            <stroke
                android:width="1dp"
                android:color="#405DADE2" />
        </shape>
    </item>
    
    <!-- TOP RIM HIGHLIGHT -->
    <item android:bottom="4dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape>
            <corners android:radius="32dp" />
            <stroke
                android:width="2dp"
                android:color="#20FFFFFF" />
        </shape>
    </item>
</layer-list>
