<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- BASE LAYER: ULTRA HIGH PREMIUM CRYSTAL WHITE -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F8FAFF" />
        </shape>
    </item>

    <!-- CENTER BLOOM (SOFT AZURE GLOW) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="1000dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#1A5B9FF9"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- TOP-RIGHT BLOOM (VIBRANT SKY GLOW) -->
    <item android:top="-100dp" android:right="-100dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:centerX="1.0"
                android:centerY="0.0"
                android:startColor="#2641B8FF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- BOTTOM-LEFT BLOOM (ETHEREAL LAVENDER GLOW) -->
    <item android:bottom="-200dp" android:left="-100dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="800dp"
                android:centerX="0.0"
                android:centerY="1.0"
                android:startColor="#1F948AFE"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- GLASS TEXTURE NOISE (SUBTLE OVERLAY) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#0DFFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
