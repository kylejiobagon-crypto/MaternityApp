<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Charcoal Depth Shadow -->
    <item android:top="4dp" android:left="4dp" android:right="0dp" android:bottom="0dp">
         <shape android:shape="rectangle">
             <corners android:radius="30dp" />
             <solid android:color="#40000000" />
         </shape>
    </item>

    <!-- Main Body Background (Navy to Ice Silver Gradient) -->
    <item android:bottom="4dp" android:right="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0F172A"
                android:centerY="0.5"
                android:endColor="#334155"
                android:angle="0" />
            <corners android:radius="30dp" />
        </shape>
    </item>

    <!-- Inner Glow / Bevel Rim Light -->
    <item android:bottom="4dp" android:right="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <stroke android:width="1.2dp" android:color="#4DFFFFFF" />
            <corners android:radius="30dp" />
        </shape>
    </item>

    <!-- Premium Glossy White Reflection Layer -->
    <item android:bottom="80dp" android:right="12dp" android:left="12dp" android:top="6dp">
         <shape android:shape="rectangle">
             <gradient
                 android:startColor="#40FFFFFF"
                 android:endColor="#00FFFFFF"
                 android:angle="270" />
             <corners android:topLeftRadius="24dp" android:topRightRadius="24dp" />
         </shape>
    </item>

    <!-- Highlight Shine Gradient Overlay (Subtle White) -->
    <item android:bottom="4dp" android:right="2dp" android:left="2dp">
         <shape android:shape="rectangle">
             <gradient
                 android:startColor="#1AFFFFFF"
                 android:endColor="#00000000"
                 android:angle="315" />
             <corners android:radius="30dp" />
         </shape>
    </item>
</layer-list>
