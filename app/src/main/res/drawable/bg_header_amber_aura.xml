<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#F59E0B"
                android:centerColor="#D97706"
                android:endColor="#B45309"
                android:angle="0" />
        </shape>
    </item>
    <item>
        <bitmap
            android:src="@drawable/grid_pattern_aura"
            android:tileMode="repeat"
            android:alpha="0.1" />
    </item>
    <!-- Top-Line Shine -->
    <item android:bottom="118dp">
        <shape android:shape="rectangle">
            <solid android:color="#4DFFFFFF" />
        </shape>
    </item>
</layer-list>
