<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow Layer (Subtle Navy Aura) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#20000000" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <!-- Main Gradient (Electric Blue -> Deep Sea) -->
    <item android:bottom="4dp" android:right="2dp" android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#2563EB"
                android:centerColor="#1D4ED8"
                android:endColor="#1E3A8A"
                android:angle="0" />
            <corners android:radius="16dp" />
            <stroke android:width="1.2dp" android:color="#4DFFFFFF" />
        </shape>
    </item>

    <!-- Glossy Top-Reflection Line -->
    <item android:bottom="40dp" android:right="8dp" android:top="4dp" android:left="8dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#66FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</layer-list>
