<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <padding android:bottom="6dp" android:left="4dp" android:right="4dp" android:top="2dp" />
            <solid android:color="#20B049FF" /> <!-- Purple shadow glow -->
            <corners android:radius="26dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#5919233C" /> 
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="#B049FF" /> 
        </shape>
    </item>
    <!-- INTERNAL GRADIENT HIGHLIGHT (Deep Lavender to Cosmic Purple) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="225"
                android:startColor="#26B049FF"
                android:endColor="#005A18C9" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
