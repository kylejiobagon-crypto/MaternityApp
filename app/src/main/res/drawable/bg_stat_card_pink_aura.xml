<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Ambient Shadow (Matching Pink) -->
    <item>
        <shape android:shape="rectangle">
            <padding android:bottom="8dp" android:left="4dp" android:right="4dp" android:top="4dp" />
            <solid android:color="#26EC4899" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Main Vibrant Pink-to-Rose Gradient -->
    <item android:bottom="4dp" android:right="2dp" android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#F43F5E"
                android:centerColor="#EC4899"
                android:endColor="#BE185D"
                android:angle="135" />
            <corners android:radius="24dp" />
            <stroke android:width="1.2dp" android:color="#4DFFFFFF" />
        </shape>
    </item>

    <!-- Glowing Top Reflection -->
    <item android:bottom="50dp" android:right="20dp" android:top="10dp" android:left="10dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#80FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
