<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Drop Shadow / Glow Base (Intense Shadow) -->
    <item android:top="8dp" android:left="3dp" android:right="3dp" android:bottom="-6dp">
        <shape android:shape="rectangle">
            <solid android:color="#20007AFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- Main Card Body (Vibrant Cyan-Blue Liquid) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00E5FF"
                android:endColor="#007AFF"
                android:angle="135" />
            <corners android:radius="28dp" />
            <stroke android:width="1.5dp" android:color="#33FFFFFF" />
        </shape>
    </item>

    <!-- Center Soft Shine Layer -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#66FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="26dp" />
        </shape>
    </item>

    <!-- Micro-Bottom Inner Shade (Concave effect) -->
    <item android:top="40dp" android:bottom="4dp" android:left="8dp" android:right="8dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00FFFFFF"
                android:endColor="#22000000"
                android:angle="270" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</layer-list>
