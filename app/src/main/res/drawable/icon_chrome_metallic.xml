<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#475569" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#F1F5F9"
                android:centerColor="#64748B"
                android:endColor="#94A3B8"
                android:angle="145" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#80FFFFFF"/>
        </shape>
    </item>
    <item android:bottom="6dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <gradient android:startColor="#BFFFFFFF" android:endColor="#00FFFFFF" android:angle="270"/>
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
