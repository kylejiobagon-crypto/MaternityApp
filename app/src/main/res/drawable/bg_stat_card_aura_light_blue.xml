<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Gradient Body: Soft Premium Blue -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#4A90E2"
                android:centerColor="#357ABD"
                android:endColor="#2D6392"
                android:angle="135" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Glossy Top-Highlight Shadow-Effect -->
    <item android:bottom="60dp" android:right="30dp">
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.0"
                android:centerY="0.0"
                android:gradientRadius="120dp"
                android:startColor="#4DFFFFFF" 
                android:endColor="#00FFFFFF" 
                android:type="radial" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- 3D Glass Rim Shine -->
    <item android:bottom="2dp" android:right="2dp" android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke android:width="1.2dp" android:color="#40FFFFFF" />
        </shape>
    </item>
</layer-list>
