<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom Shadow -->
    <item android:top="4dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#0D4EE0E0" />
        </shape>
    </item>
    <!-- Main Glass Body -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#F20D2321"
                android:endColor="#F2102020"
                android:angle="135" />
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="#26FFFFFF" />
        </shape>
    </item>
    <!-- Cyan Neon Glow Overlay -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:startColor="#1A00FBFB"
                android:endColor="#00000000"
                android:centerX="0.2"
                android:centerY="0.2"
                android:type="radial"
                android:gradientRadius="120dp" />
        </shape>
    </item>
</layer-list>
