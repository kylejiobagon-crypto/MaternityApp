<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow/Bottom depth -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#003296" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    
    <!-- Main Gradient -->
    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1E90FF"
                android:endColor="#003296"
                android:angle="145" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#4DFFFFFF"/>
        </shape>
    </item>
    
    <!-- Top inner highlight -->
    <item android:bottom="4dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <gradient android:startColor="#33FFFFFF" android:endColor="#00FFFFFF" android:angle="270"/>
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
