<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle Outer Glow/Border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#0D000000" />
        </shape>
    </item>
    <!-- Card Body with Dynamic Tint Feel -->
    <item android:bottom="1dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp" />
            <gradient
                android:angle="135"
                android:startColor="#F8FAFC"
                android:endColor="#F1F5F9" />
            <stroke android:width="1dp" android:color="#1A6366F1" /> <!-- Subtle Indigo Tint -->
        </shape>
    </item>
</layer-list>
