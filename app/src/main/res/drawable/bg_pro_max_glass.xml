<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. ULTRA-TRANSLUCENT FROSTED BASE (12% White) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1FFFFFFF" />
            <corners android:radius="36dp" />
        </shape>
    </item>

    <!-- 2. INNER GLOW / HIGHLIGHT (Top Edge) -->
    <item android:top="0.5dp" android:left="0.5dp" android:right="0.5dp">
        <shape android:shape="rectangle">
            <corners android:radius="36dp" />
            <stroke android:width="1dp" android:color="#4DFFFFFF" />
        </shape>
    </item>

    <!-- 3. SUBTLE CRYSTAL STROKE (1dp Silver-White) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="36dp" />
            <stroke android:width="0.8dp">
                <gradient
                    android:type="linear"
                    android:angle="135"
                    android:startColor="#80FFFFFF"
                    android:endColor="#1AFFFFFF" />
            </stroke>
        </shape>
    </item>

    <!-- 4. BOTTOM DEPTH SHADOW (Subtle) -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="0.5dp">
        <shape android:shape="rectangle">
            <corners android:radius="36dp" />
            <stroke android:width="0.5dp" android:color="#0D000000" />
        </shape>
    </item>
</layer-list>
