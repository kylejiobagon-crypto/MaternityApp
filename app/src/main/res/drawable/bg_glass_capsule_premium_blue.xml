<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. HIGHLY POLISHED GLASS FILL (40% White) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#7AFFFFFF" />
            <corners android:radius="40dp" />
        </shape>
    </item>

    <!-- 2. COBALT GRADIENT STROKE -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="40dp" />
            <stroke android:width="1.2dp">
                <gradient
                    android:type="linear"
                    android:angle="270"
                    android:startColor="#C0C0C0"
                    android:endColor="#003366" />
            </stroke>
        </shape>
    </item>

    <!-- 3. TOP GLOSS SHEEN -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="20dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#B3FFFFFF"
                android:endColor="#00000000" />
            <corners android:radius="39dp" />
        </shape>
    </item>
</layer-list>
