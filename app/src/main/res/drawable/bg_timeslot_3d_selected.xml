<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Extremely bright cyan base shadow -->
    <item android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#0066FF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Brilliant cyan gradient body -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient android:startColor="#00FBFB" android:endColor="#00A2FF" android:angle="135" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Inner bright edge -->
    <item android:top="1dp" android:bottom="5dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <gradient android:startColor="#66FFFFFF" android:endColor="#00FFFFFF" android:angle="270" />
            <corners android:radius="15dp" />
        </shape>
    </item>
</layer-list>
