<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Light Glow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D007AFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Glass Surface -->
    <item android:bottom="4dp" android:right="2dp" android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#0FFFFFFF" /> <!-- Highly transparent -->
            <corners android:radius="14dp" />
            <stroke android:width="1.2dp" android:color="#4DFFFFFF" />
        </shape>
    </item>
</layer-list>
