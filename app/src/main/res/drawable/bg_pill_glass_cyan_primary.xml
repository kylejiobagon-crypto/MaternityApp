<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow / Cyan Shadow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="40dp"/>
            <stroke android:width="1dp" android:color="@color/billing_neon_cyan"/>
            <solid android:color="#2000FBFB" /> <!-- Low opacity cyan fill -->
        </shape>
    </item>
    <!-- Cyan Rim Highlight -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="40dp"/>
            <stroke android:width="1.5dp" android:color="#4DFFFFFF" />
        </shape>
    </item>
</layer-list>
