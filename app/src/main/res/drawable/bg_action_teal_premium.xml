<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="0dp">
         <shape android:shape="rectangle">
             <corners android:radius="28dp" />
             <solid android:color="#26000000" />
         </shape>
    </item>
    <item android:bottom="3dp" android:right="1dp" android:left="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#10B981"
                android:endColor="#059669"
                android:angle="135" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item android:bottom="3dp" android:right="1dp" android:left="1dp">
        <shape android:shape="rectangle">
            <stroke android:width="1.2dp" android:color="#4DFFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item android:bottom="30dp" android:right="8dp" android:left="8dp" android:top="4dp">
         <shape android:shape="rectangle">
             <gradient
                 android:startColor="#40FFFFFF"
                 android:endColor="#00FFFFFF"
                 android:angle="270" />
             <corners android:topLeftRadius="18dp" android:topRightRadius="18dp" />
         </shape>
    </item>
</layer-list>
