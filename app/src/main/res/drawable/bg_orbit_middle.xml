<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/secondaryProgress">
        <shape android:innerRadiusRatio="3.5" android:shape="ring" android:thicknessRatio="18.0" android:useLevel="true">
            <solid android:color="#0D000000" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <rotate android:fromDegrees="270" android:pivotX="50%" android:pivotY="50%" android:toDegrees="270">
            <shape android:innerRadiusRatio="3.5" android:shape="ring" android:thicknessRatio="18.0" android:useLevel="true">
                <gradient android:startColor="#0EA5E9" android:endColor="#0284C7" android:type="sweep" />
            </shape>
        </rotate>
    </item>
</layer-list>
