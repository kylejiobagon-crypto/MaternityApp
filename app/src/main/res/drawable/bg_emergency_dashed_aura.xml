<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Red Accent Inner Glow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0DFF2D55" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Dashed Border Surface -->
    <item android:bottom="4dp" android:right="2dp" android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#0DFF2D55" />
            <corners android:radius="22dp" />
            <stroke
                android:width="2dp"
                android:color="#FF2D55"
                android:dashWidth="8dp"
                android:dashGap="4dp" />
        </shape>
    </item>
</layer-list>
