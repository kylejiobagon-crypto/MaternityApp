<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Body Gradient: Soft 3D Depth -->
    <item>
        <shape>
            <gradient
                android:startColor="#FAFBFC"
                android:centerColor="#FCFDFF"
                android:endColor="#FFFFFF"
                android:angle="135" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- Inner Highlight: Glossy Rim -->
    <item
        android:top="1dp"
        android:left="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape>
            <stroke
                android:width="1dp"
                android:color="#E1E4E8" />
            <corners android:radius="27.5dp" />
        </shape>
    </item>
</layer-list>
