<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_aura_mesh">

    <!-- ✅ 1. GLASSMORPHIC CHAT HEADER -->
    <RelativeLayout
        android:id="@+id/chat_view_header"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_glass_card_premium_light"
        android:elevation="16dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBackView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#1E293B" />

        <RelativeLayout
            android:id="@+id/headerAvatarContainer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/btnBackView"
            android:layout_marginStart="8dp">
            
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivHeaderAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                app:shapeAppearanceOverlay="@style/RoundedProfileAvatar" />
                
            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:background="@drawable/bg_dot_emerald_glow" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="14dp"
            android:layout_toEndOf="@id/headerAvatarContainer"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvHeaderName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dr. Reyes, OB-GYN"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active Now"
                android:textColor="#10B981"
                android:textSize="10sp"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>
        
        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_call"
            app:tint="#6366F1" />
    </RelativeLayout>

    <!-- ✅ 2. MESSAGE LIST (ZERO-GRAVITY) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/input_area"
        android:layout_below="@id/chat_view_header"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_message_sent" />

    <!-- Mock Typing Indicator -->
    <LinearLayout
        android:id="@+id/typing_indicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/input_area"
        android:paddingHorizontal="24dp"
        android:paddingBottom="12dp"
        android:layout_marginStart="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="visible">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Midwife is typing..."
            android:textColor="#64748B"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- ✅ 3. SMART FROSTED INPUT BAR -->
    <RelativeLayout
        android:id="@+id/input_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:padding="4dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_frosted_input_bar"
            android:elevation="10dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnAddMedia"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_input_add"
                app:tint="#64748B" />

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toEndOf="@id/btnAddMedia"
                android:layout_toStartOf="@+id/btnMic"
                android:layout_marginHorizontal="12dp"
                android:background="@android:color/transparent"
                android:hint="Type message..."
                android:textColor="#1E293B"
                android:textColorHint="#94A3B8"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:id="@+id/btnMic"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@+id/btnSend"
                android:layout_marginEnd="12dp"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="#64748B" />

            <RelativeLayout
                android:id="@+id/btnSend"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_send_btn_glow"
                android:elevation="4dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerInParent="true"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="#FFFFFF" />
            </RelativeLayout>
        </RelativeLayout>
    </RelativeLayout>

</RelativeLayout>
