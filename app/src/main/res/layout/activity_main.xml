<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavContainer"
        android:fillViewport="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- Dynamic Header Background Frame -->
            <FrameLayout
                android:id="@+id/headerFrame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#6366F1"> 
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="32dp"
                    android:paddingBottom="48dp"
                    android:paddingHorizontal="24dp">
                    
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp">
                        
                        <ImageView
                            android:id="@+id/ivMenu"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_alignParentStart="true"
                            android:src="@android:drawable/ic_menu_sort_by_size"
                            app:tint="#FFFFFF" />
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:orientation="horizontal">
                            <View android:layout_width="4dp" android:layout_height="14dp" android:background="#FFFFFF" android:layout_marginEnd="4dp" />
                            <View android:layout_width="4dp" android:layout_height="8dp" android:background="#FFFFFF" android:layout_marginEnd="4dp" />
                            <View android:layout_width="4dp" android:layout_height="4dp" android:background="#FFFFFF" />
                        </LinearLayout>
                    </RelativeLayout>
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <androidx.cardview.widget.CardView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            app:cardCornerRadius="30dp"
                            app:cardElevation="4dp"
                            app:cardBackgroundColor="#FFFFFF">
                            <ImageView
                                android:id="@+id/ivDashboardLogo"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="2dp"
                                android:scaleType="centerCrop"
                                android:src="@android:drawable/ic_menu_myplaces" />
                        </androidx.cardview.widget.CardView>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">
                            
                            <TextView
                                android:id="@+id/tvDashboardTagline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="YOUR HEALTH IN YOUR HANDS"
                                android:textColor="#CCFFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textAllCaps="true" />
                                
                            <TextView
                                android:id="@+id/tvDashboardTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Loading App..."
                                android:textColor="#FFFFFF"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-24dp"
                android:layout_marginHorizontal="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <androidx.cardview.widget.CardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#FFF3E0"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="16dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_today"
                            app:tint="#F97316" />
                    </androidx.cardview.widget.CardView>
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Next Appt."
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1E293B" />
                        <TextView
                            android:id="@+id/tvNextBooking"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No upcoming visit"
                            android:textSize="12sp"
                            android:textColor="#64748B" />
                    </LinearLayout>
                    
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#CBD5E1" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            
            <TextView
                android:id="@+id/tvServicesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Our Services"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#1E293B"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />
                
            <LinearLayout
                android:id="@+id/servicesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="24dp">
                
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#EFF6FF"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="#3B82F6"
                            android:layout_marginBottom="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Maternity"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#334155" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FDF2F8"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_gallery"
                            app:tint="#EC4899"
                            android:layout_marginBottom="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pediatrics"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#334155" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
            
            <androidx.cardview.widget.CardView
                android:id="@+id/cvActionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#171717"
                app:cardElevation="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    android:paddingHorizontal="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Book a Checkup"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Access your medical records and track your pregnancy."
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp"
                        android:textAlignment="center"
                        android:layout_marginBottom="16dp" />
                    <Button
                        android:id="@+id/btnSchedule"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Schedule Now"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#171717"
                        android:backgroundTint="#FFFFFF"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Hidden old fields used by MainActivity.java temporarily to not crash -->
            <TextView android:id="@+id/tvUserFullname" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/tvPendingBills" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/tvRecordsCount" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <Button android:id="@+id/btnRefresh" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <Button android:id="@+id/btnLogout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
    
    <!-- Custom Bottom Navigation -->
    <RelativeLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_alignParentBottom="true"
            android:background="#FFFFFF"
            android:elevation="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp">
            
            <ImageView
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#6366F1" />
                
            <ImageView
                android:id="@+id/navAppointments"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_today"
                app:tint="#CBD5E1" />
                
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" /> 
                
            <ImageView
                android:id="@+id/navRecords"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="#CBD5E1" />
                
            <ImageView
                android:id="@+id/navLogout"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_info_details"
                app:tint="#CBD5E1" />
        </LinearLayout>
        
        <!-- Big Floating Add Button in the center over the nav bar -->
        <androidx.cardview.widget.CardView
            android:id="@+id/fabAction"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_centerHorizontal="true"
            android:layout_alignParentTop="true"
            app:cardCornerRadius="32dp"
            app:cardBackgroundColor="#6366F1"
            app:cardElevation="28dp">
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_input_add"
                app:tint="#FFFFFF" />
        </androidx.cardview.widget.CardView>
    </RelativeLayout>
</RelativeLayout>