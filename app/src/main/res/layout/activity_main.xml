<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_soft_gray_bg">

    <!-- MAIN CONTENT WRAPPER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- 1. SCROLLABLE DASHBOARD -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:paddingBottom="140dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 1. FLOATING 3D HEADER SECTION -->
                <RelativeLayout
                    android:id="@+id/header_container"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_header_floating_3d"
                    android:elevation="20dp">

                    <LinearLayout
                        android:id="@+id/profilePicContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="h"
                            android:textColor="@color/orange_primary"
                            android:textSize="32sp"
                            android:fontFamily="sans-serif-condensed-medium"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ey, "
                            android:textColor="#0F172A"
                            android:textSize="29sp"
                            android:fontFamily="sans-serif-condensed-medium"
                            android:letterSpacing="-0.03" />
                        <TextView
                            android:id="@+id/tvWelcomeName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="dustin pogi"
                            android:textColor="#0F172A"
                            android:textSize="29sp"
                            android:fontFamily="sans-serif-condensed-medium"
                            android:letterSpacing="-0.03" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/navChat"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="16dp"
                            android:src="@android:drawable/ic_menu_send"
                            app:tint="#64748B"
                            android:elevation="4dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <RelativeLayout
                            android:id="@+id/ivMenu"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_header_button_orange_premium"
                            android:elevation="12dp"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_centerInParent="true"
                                android:src="@android:drawable/ic_menu_sort_by_size"
                                app:tint="#FFFFFF" />
                        </RelativeLayout>

                        <!-- Ghost logout link -->
                        <View android:id="@+id/btnLogout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                    </LinearLayout>
                </RelativeLayout>

                <!-- 2. MAIN HERO: WIDE GLASSMORPHIC STATUS -->
                <RelativeLayout
                    android:id="@+id/hero_card"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_charcoal_premium_card"
                    android:elevation="20dp"
                    android:clipToOutline="true"
                    android:padding="20dp">

                    <!-- Moving Smoke Effect Layer (White smoke for dark mode) -->
                    <View
                        android:id="@+id/smokeEffectSurface"
                        android:layout_width="600dp"
                        android:layout_height="600dp"
                        android:layout_centerInParent="true"
                        android:alpha="0.1"
                        android:background="@drawable/bg_smoke_gradient_layer" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <!-- SECTION 1: MATERNITY WAVE GRAPH (BEZIER) -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="100dp">
                            
                            <!-- Custom Wave View -->
                            <com.example.alagwaapp.MaternityWaveView
                                android:id="@+id/maternityWaveView"
                                android:layout_width="match_parent"
                                android:layout_height="80dp"
                                android:layout_centerInParent="true" />
                                
                            <!-- TOP OVERLAY: Trimester Label (DARK STYLE FOR VISIBILITY) -->
                            <TextView
                                android:id="@+id/tvOrbitSubValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:layout_centerHorizontal="true"
                                android:text="2nd Trimester"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-black"
                                android:letterSpacing="0.1"
                                android:background="@drawable/bg_orbit_outer"
                                android:backgroundTint="#0F172A"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="4dp" />
                        </RelativeLayout>

                        <!-- SECTION 2: WAVE HUD (Heads Up Display) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <!-- Weeks Big Value -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvOrbitValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="24"
                                    android:textColor="#FFFFFF"
                                    android:textSize="32sp"
                                    android:fontFamily="sans-serif-black"
                                    android:includeFontPadding="false"
                                    android:shadowColor="#40000000"
                                    android:shadowDx="2"
                                    android:shadowDy="2"
                                    android:shadowRadius="4" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="WEEKS"
                                    android:textColor="#94A3B8"
                                    android:textSize="8sp"
                                    android:fontFamily="sans-serif-black"
                                    android:letterSpacing="0.2" />
                            </LinearLayout>

                            <!-- Divider (Vertical) -->
                            <View
                                android:layout_width="1dp"
                                android:layout_height="32dp"
                                android:layout_marginHorizontal="24dp"
                                android:background="#40FFFFFF" />

                            <!-- Due Date & Progress HUD -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvDetailDueDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Due on July 15, 2026"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-black" />
                                <TextView
                                    android:id="@+id/tvDetailWeeks"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="16 milestone weeks to go"
                                    android:textColor="#CBD5E1"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif-black"
                                    android:alpha="1" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Ghost View for Timeline compatibility (Hidden) -->
                    <ProgressBar
                        android:id="@+id/viewTimelineProgress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="invisible" />

                </RelativeLayout>

                <!-- 3. QUICK ACTIONS: PILL CAPSULES -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:scrollbars="none"
                    android:clipToPadding="false"
                    android:paddingHorizontal="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="8dp">

                        <TextView
                            android:id="@+id/qaWalkIn"
                            android:layout_width="wrap_content"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_orange_premium_accent"
                            android:elevation="8dp"
                            android:gravity="center"
                            android:paddingHorizontal="24dp"
                            android:text="Walk-In Queue"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-bold"
                            android:layout_marginEnd="12dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/qaBookAppt"
                            android:layout_width="wrap_content"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_action_blue_premium"
                            android:elevation="8dp"
                            android:gravity="center"
                            android:paddingHorizontal="24dp"
                            android:text="Schedule Visit"
                            android:textColor="#FFFFFF"
                            android:fontFamily="sans-serif-bold"
                            android:textSize="14sp"
                            android:layout_marginEnd="12dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/qaViewBilling"
                            android:layout_width="wrap_content"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_action_teal_premium"
                            android:elevation="8dp"
                            android:gravity="center"
                            android:paddingHorizontal="24dp"
                            android:text="Financial"
                            android:textColor="#FFFFFF"
                            android:fontFamily="sans-serif-bold"
                            android:textSize="14sp"
                            android:layout_marginEnd="12dp"
                            android:clickable="true"
                            android:focusable="true" />
                        
                        <TextView
                            android:id="@+id/qaViewRecords"
                            android:layout_width="wrap_content"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_action_violet_premium"
                            android:elevation="8dp"
                            android:gravity="center"
                            android:paddingHorizontal="24dp"
                            android:text="Medical Records"
                            android:textColor="#FFFFFF"
                            android:fontFamily="sans-serif-bold"
                            android:textSize="14sp"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- 4. STATISTICS GRID (2x2 Squircles) -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="380dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="20dp"
                    android:columnCount="2"
                    android:rowCount="2">

                    <!-- Appointments (White Glass Squircle) -->
                    <RelativeLayout
                        android:id="@+id/statCardToday"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_rowWeight="1"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:background="@drawable/bg_white_glassmorphic"
                        android:elevation="10dp"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_today"
                            app:tint="#FF9F1C" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="Appointments\nToday"
                            android:textColor="#64748B"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="start" />
                        <TextView
                            android:id="@+id/tvStatValue1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:text="0"
                            android:textColor="#0F172A"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                    </RelativeLayout>

                    <!-- Upcoming (Charcoal Squircle) -->
                    <RelativeLayout
                        android:id="@+id/statCardUpcoming"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_rowWeight="1"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:background="@drawable/bg_charcoal_premium_card"
                        android:elevation="12dp"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_recent_history"
                            app:tint="#FFFFFFFF" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="Upcoming\nNext Visits"
                            android:textColor="#94A3B8"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:id="@+id/tvStatValue2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                    </RelativeLayout>

                    <!-- Financial (Charcoal Squircle) -->
                    <RelativeLayout
                        android:id="@+id/statCardBilling"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_rowWeight="1"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:background="@drawable/bg_charcoal_premium_card"
                        android:elevation="12dp"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_save"
                            app:tint="#FFFFFFFF" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="Financial\nPending Bills"
                            android:textColor="#94A3B8"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:id="@+id/tvStatValue3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                    </RelativeLayout>

                    <!-- Records (White Glass Squircle) -->
                    <RelativeLayout
                        android:id="@+id/statCardRecords"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_rowWeight="1"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:background="@drawable/bg_white_glassmorphic"
                        android:elevation="10dp"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="#FF9F1C" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="Records\nMedical History"
                            android:textColor="#64748B"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:id="@+id/tvStatValue4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:text="0"
                            android:textColor="#0F172A"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                    </RelativeLayout>
                </GridLayout>

                <!-- 5. RECENT APPOINTMENT (Optional Polish) -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recent Appointment"
                        android:textColor="#0F172A"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black" />
                    <TextView
                        android:id="@+id/tvSeeAllAppts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="See All ›"
                        android:textColor="@color/orange_primary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:clickable="true"
                        android:focusable="true" />
                </RelativeLayout>
                    
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:background="@drawable/bg_white_neumorphic_card"
                    android:padding="20dp"
                    android:elevation="8dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <RelativeLayout android:layout_width="52dp" android:layout_height="64dp" android:background="@drawable/bg_charcoal_premium_card" android:elevation="4dp">
                             <TextView android:id="@+id/tvApptDate1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerHorizontal="true" android:layout_marginTop="10dp" android:text="27" android:textColor="#FFFFFF" android:textSize="22sp" android:fontFamily="sans-serif-black" />
                             <TextView android:id="@+id/tvApptMonth1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerHorizontal="true" android:layout_alignParentBottom="true" android:layout_marginBottom="10dp" android:text="MAR" android:textColor="#FFFFFF" android:textSize="10sp" android:alpha="0.7" />
                        </RelativeLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginStart="20dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvApptTitle1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No Appointments" android:textColor="#0F172A" android:textSize="16sp" android:fontFamily="sans-serif-bold" />
                            <TextView android:id="@+id/tvApptTime1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Update your schedule" android:textColor="#64748B" android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>
        </ScrollView>

        <!-- 2. ULTRA-PREMIUM BOTTOM NAVIGATION (Strict Pin) -->
        <FrameLayout
            android:id="@+id/nav_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true">
            <include layout="@layout/layout_bottom_nav" />
        </FrameLayout>

    </RelativeLayout>

    <!-- Drawer Fragment Placeholder -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#1E293B"
        app:itemTextColor="#FFFFFF"
        app:itemIconTint="#FFFFFF"
        app:itemHorizontalPadding="16dp"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu" />

</androidx.drawerlayout.widget.DrawerLayout>