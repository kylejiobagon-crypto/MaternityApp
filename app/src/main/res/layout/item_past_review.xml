<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_glass_card_dark_realapp"
    android:elevation="12dp"
    android:orientation="vertical"
    android:padding="24dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">
        
        <TextView
            android:id="@+id/tvPastDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Checked: March 15, 2026"
            android:textColor="#BBFFD8"
            android:textSize="11sp"
            android:fontFamily="sans-serif-bold"
            android:alpha="0.6" />

        <!-- Rating Stars (Simple Row) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal">
            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FACC15" />
            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FACC15" />
            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FACC15" />
            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FACC15" />
            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="#FACC15" />
        </LinearLayout>
    </RelativeLayout>

    <TextView
        android:id="@+id/tvFeedbackContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Napakabait ng staff at mas mabilis na ang process ngayon! Salamat, Alagwa!"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="16dp" />

    <!-- CLINIC REPLY INDICATOR -->
    <LinearLayout
        android:id="@+id/llClinicReply"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1AFFFFFF"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/ic_dialog_email"
            app:tint="@color/electric_cyan"
            android:layout_marginEnd="8dp" />
        <TextView
            android:id="@+id/tvClinicReplyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Replied: We're glad you liked the service, Mommy!"
            android:textColor="@color/electric_cyan"
            android:textSize="11sp"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

</LinearLayout>
