<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_glass"
    android:orientation="vertical"
    android:padding="24dp"
    android:clipToPadding="false"
    android:elevation="16dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#D1D5DB"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Official Receipt"
        android:textColor="#0B0E11"
        android:textSize="20sp"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- 3D Receipt Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_receipt_card"
        android:elevation="4dp"
        android:padding="20dp"
        android:layout_marginBottom="24dp">
        
        <TextView
            android:id="@+id/bsClinicName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alagwa Maternity Clinic"
            android:textColor="#0B0E11"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/bsClinicAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="123 Healthcare St, Medical District"
            android:textColor="#6B7280"
            android:textSize="10sp"
            android:fontFamily="sans-serif-bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/bsInvoiceId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="#PAY-0001"
            android:textColor="#6B7280"
            android:textSize="10sp"
            android:fontFamily="sans-serif-bold"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/bsTotalAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="₱0.00"
            android:textColor="#0B0E11"
            android:textSize="32sp"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/bsStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Payment Complete"
            android:textColor="#00F49C"
            android:textSize="11sp"
            android:fontFamily="sans-serif-bold"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginBottom="16dp" />

        <!-- Itemized Breakdown -->
        <LinearLayout android:id="@+id/rowServices" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="12dp" android:visibility="gone">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="SERVICES" android:textColor="#0B0E11" android:textSize="10sp" android:fontFamily="sans-serif-black" android:layout_marginBottom="4dp" />
            <TextView android:id="@+id/bsServicesList" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Prenatal Checkup\n• Lab Test" android:textColor="#4B5563" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:lineSpacingExtra="2dp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/rowMedications" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="16dp" android:visibility="gone">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="MEDICATIONS" android:textColor="#0B0E11" android:textSize="10sp" android:fontFamily="sans-serif-black" android:layout_marginBottom="4dp" />
            <TextView android:id="@+id/bsMedicationsList" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Folic Acid (x30)\n• Ferrous Sulfate (x30)" android:textColor="#4B5563" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:lineSpacingExtra="2dp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginBottom="16dp" />

        <!-- Line Items -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Subtotal" android:textColor="#6B7280" android:textSize="14sp" />
            <TextView android:id="@+id/bsSubtotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₱0.00" android:textColor="#0B0E11" android:textSize="14sp" android:fontFamily="sans-serif-bold" />
        </LinearLayout>

        <LinearLayout android:id="@+id/bsDiscountRow" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp" android:visibility="gone">
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="PH Discount" android:textColor="#00F49C" android:textSize="14sp" />
            <TextView android:id="@+id/bsDiscount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-₱0.00" android:textColor="#00F49C" android:textSize="14sp" android:fontFamily="sans-serif-bold" />
        </LinearLayout>

        <LinearLayout android:id="@+id/bsDownpaymentRow" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp" android:visibility="gone">
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Downpayment" android:textColor="#F472B6" android:textSize="14sp" />
            <TextView android:id="@+id/bsDownpaymentApplied" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-₱0.00" android:textColor="#F472B6" android:textSize="14sp" android:fontFamily="sans-serif-bold" />
        </LinearLayout>
        
        <!-- Perforated Tear Line -->
        <View android:layout_width="match_parent" android:layout_height="2dp" android:background="@drawable/bg_dashed_line" android:layout_marginBottom="16dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Final Total" android:textColor="#0B0E11" android:textSize="16sp" android:fontFamily="sans-serif-black" />
            <TextView android:id="@+id/bsFinalTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₱0.00" android:textColor="#0B0E11" android:textSize="16sp" android:fontFamily="sans-serif-black" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/btnDownloadPdf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_button_glow_cyan"
        android:paddingVertical="14dp"
        android:text="Download PDF Receipt"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-bold"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:elevation="4dp" />

</LinearLayout>
