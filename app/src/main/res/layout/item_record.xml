<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header: Service & Date -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvRecordService"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prenatal Check-up"
                    android:textColor="#1E293B"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-black" />
                <TextView
                    android:id="@+id/tvRecordDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="March 24, 2026"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvRecordAOG"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_action_blue_premium"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="24w 2d"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black" />
        </RelativeLayout>

        <!-- AURA STATS BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F1F5F9"
            android:padding="12dp"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Weight -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#6366F1"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:id="@+id/tvItemWeight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="62kg"
                    android:textColor="#1E293B"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>

            <!-- BP -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_menu_today"
                    app:tint="#EF4444"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:id="@+id/tvItemBP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="110/80"
                    android:textColor="#1E293B"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>

            <!-- Heart -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_menu_view"
                    app:tint="#EC4899"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:id="@+id/tvItemFHT"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="140bpm"
                    android:textColor="#1E293B"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/btnViewDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="VIEW CLINICAL DETAILS ›"
            android:textColor="#2563EB"
            android:textSize="12sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
