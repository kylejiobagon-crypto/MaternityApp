<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:background="@drawable/bg_mocha_header"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="24dp">

    <androidx.cardview.widget.CardView
        android:layout_width="64dp"
        android:layout_height="64dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="4dp">
        <ImageView
            android:id="@+id/ivNavHeaderLogo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="@color/primary" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvNavHeaderTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Alagwa Patient"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:fontFamily="sans-serif-black" />

    <TextView
        android:id="@+id/tvNavHeaderEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Manage your secondary actions"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:alpha="0.8" />

</LinearLayout>
