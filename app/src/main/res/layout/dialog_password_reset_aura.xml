<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_sheet_white_premium"
    android:orientation="vertical"
    android:paddingBottom="40dp">

    <!-- Gold-Amber Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/bg_header_amber_aura" 
        android:padding="24dp">
        <!-- I used vibrant purple as a base but I'll update it to Gold Amber if I have it -->
        
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_lock_idle_lock"
            app:tint="#FFFFFF" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="44dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="SECURE ACCESS"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Update your security credentials"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NEW PASSWORD" android:textColor="#6B7280" android:textSize="8sp" android:fontFamily="sans-serif-black" android:letterSpacing="0.1" />
        <EditText android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/bg_edittext_glow_aura" android:inputType="textPassword" android:layout_marginTop="4dp" android:paddingHorizontal="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="CONFIRM PASSWORD" android:textColor="#6B7280" android:textSize="8sp" android:fontFamily="sans-serif-black" android:letterSpacing="0.1" />
        <EditText android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/bg_edittext_glow_aura" android:inputType="textPassword" android:layout_marginTop="4dp" android:paddingHorizontal="16dp" />

        <TextView
            android:id="@+id/btnUpdatePass"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_stat_card_indigo_aura"
            android:gravity="center"
            android:text="UPDATE SECURITY KEY"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-black"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
