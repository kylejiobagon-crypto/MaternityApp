<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/sheetContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_sheet_ultra_3d"
        android:orientation="vertical"
        android:paddingTop="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_glass_pill"
            android:backgroundTint="#2D3A52" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:gravity="center_vertical">
            
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="#00FBFB" />
                
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvSheetDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MAR 27 • Tomorrow"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select an available time slot"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp"
                    android:paddingTop="2dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
            
            <LinearLayout
                android:id="@+id/btnSheetClose"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_glass_circle"
                android:backgroundTint="#151A26"
                android:gravity="center"
                android:elevation="6dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#4B5563" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="24dp"
            android:background="#1A2234" />

        <GridLayout
            android:id="@+id/gridTimeSlots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:columnCount="3"
            android:rowCount="3"
            android:useDefaultMargins="true">
            
            <!-- Time Slots will be injected dynamically -->

        </GridLayout>

        <FrameLayout
            android:id="@+id/btnConfirmSlot"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/bg_button_ultra_3d"
            android:elevation="12dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tvConfirmText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="CONFIRM SELECTION"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-black"
                android:textSize="14sp"
                android:letterSpacing="0.1" />
        </FrameLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
