<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_mocha_header">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="32dp"
            android:text="Ratings &amp; Feedback"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="64dp"
            android:text="Tell us about your experience"
            android:textColor="#E0FFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:alpha="0.8" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="-30dp"
        android:layout_below="@id/header"
        android:background="@drawable/bg_sheet_white"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Recent Feedbacks"
                android:textColor="@color/on_surface"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="16dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/bg_white_3d_pill"
                android:padding="32dp">
                
                <ImageView
                    android:id="@+id/imgRatings"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_centerHorizontal="true"
                    android:src="@android:drawable/btn_star"
                    app:tint="@color/on_surface_variant"
                    android:alpha="0.3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/imgRatings"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="16dp"
                    android:text="No feedback history yet"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />
            </RelativeLayout>

            <View android:layout_width="match_parent" android:layout_height="100dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/layout_bottom_nav" />

</RelativeLayout>
