<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_billing_cosmic_abyss">

    <!-- ✅ ULTRA-PREMIUM LAYER: Ambient Aura Blobs -->
    <View
        android:layout_width="450dp"
        android:layout_height="450dp"
        android:layout_marginTop="-150dp"
        android:layout_marginStart="-150dp"
        android:background="@drawable/bg_aura_blob_cyan"
        android:alpha="0.2" />

    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="-100dp"
        android:layout_marginEnd="-100dp"
        android:background="@drawable/bg_aura_blob_violet"
        android:alpha="0.15" />

    <!-- ✅ 1. ZERO-GRAVITY FLOATING HEADER -->
    <RelativeLayout
        android:id="@+id/chat_header"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:paddingHorizontal="20dp"
        android:layout_marginTop="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_glass_card_navy_premium"
            android:elevation="6dp"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Communication Hub"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:shadowColor="@color/neon_galactic_cyan"
            android:shadowRadius="8" />

        <RelativeLayout
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_glass_card_navy_premium"
            android:elevation="6dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_centerInParent="true"
                android:src="@android:drawable/ic_popup_sync"
                app:tint="@color/electric_cyan" />
        </RelativeLayout>
    </RelativeLayout>

    <!-- ✅ 2. FLOATING GLASS SEARCH HUB -->
    <RelativeLayout
        android:id="@+id/search_hub"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_below="@id/chat_header"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_glass_search_bar_dark"
        android:elevation="12dp"
        android:paddingHorizontal="20dp">
        
        <ImageView
            android:id="@+id/ic_search"
            android:layout_width="22sp"
            android:layout_height="22sp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#D1D5DB" />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="14dp"
            android:layout_toEndOf="@id/ic_search"
            android:background="@android:color/transparent"
            android:hint="Search professional..."
            android:textColor="@color/white"
            android:textColorHint="#94A3B8"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />
    </RelativeLayout>

    <!-- ✅ 3. ACTIVE CONTACTS LIST WITH REFRESH -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/search_hub"
        android:layout_marginTop="12dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChatContacts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="20dp"
            android:paddingBottom="40dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_chat_contact" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</RelativeLayout>
