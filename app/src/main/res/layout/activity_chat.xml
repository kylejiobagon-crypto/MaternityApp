<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_aura_mesh">

    <!-- ✅ 1. ZERO-GRAVITY FLOATING HEADER -->
    <RelativeLayout
        android:id="@+id/chat_header"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:paddingHorizontal="20dp"
        android:layout_marginTop="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_glass_card_premium_light"
            android:elevation="6dp"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#1E293B" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Communication Hub"
            android:textColor="#1E293B"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black" />

        <RelativeLayout
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_glass_card_premium_light"
            android:elevation="6dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_centerInParent="true"
                android:src="@android:drawable/ic_popup_sync"
                app:tint="#6366F1" />
        </RelativeLayout>
    </RelativeLayout>

    <!-- ✅ 2. FLOATING GLASS SEARCH HUB -->
    <RelativeLayout
        android:id="@+id/search_hub"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_below="@id/chat_header"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_glass_search_bar"
        android:elevation="12dp"
        android:paddingHorizontal="20dp">
        
        <ImageView
            android:id="@+id/ic_search"
            android:layout_width="22sp"
            android:layout_height="22sp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#64748B" />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="14dp"
            android:layout_toEndOf="@id/ic_search"
            android:background="@android:color/transparent"
            android:hint="Search professional..."
            android:textColor="#1E293B"
            android:textColorHint="#94A3B8"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />
    </RelativeLayout>

    <!-- ✅ 3. ACTIVE CONTACTS LIST WITH REFRESH -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/search_hub"
        android:layout_marginTop="12dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChatContacts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="20dp"
            android:paddingBottom="100dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_chat_contact" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- NAVIGATION ANCHOR -->
    <FrameLayout
        android:id="@+id/nav_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <include layout="@layout/layout_bottom_nav" />
    </FrameLayout>

</RelativeLayout>
