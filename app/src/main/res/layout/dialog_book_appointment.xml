<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Book Appointment"
        android:textColor="@color/on_surface"
        android:textSize="20sp"
        android:fontFamily="sans-serif-black" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select your visit details below"
        android:textColor="@color/on_surface_variant"
        android:textSize="12sp"
        android:layout_marginBottom="24dp" />

    <!-- Service Selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Service Type"
        android:textColor="@color/on_surface"
        android:textSize="13sp"
        android:fontFamily="sans-serif-bold"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinnerService"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_white_3d_pill"
        android:entries="@array/appointment_services"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Date Picker -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Preferred Date"
        android:textColor="@color/on_surface"
        android:textSize="13sp"
        android:fontFamily="sans-serif-bold"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etDate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_white_3d_pill"
        android:hint="YYYY-MM-DD"
        android:clickable="true"
        android:focusable="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:drawableEnd="@android:drawable/ic_menu_my_calendar"
        android:layout_marginBottom="16dp" />

    <!-- Time Selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Preferred Time"
        android:textColor="@color/on_surface"
        android:textSize="13sp"
        android:fontFamily="sans-serif-bold"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinnerTime"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_white_3d_pill"
        android:entries="@array/appointment_times"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Notes -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Special Notes (Optional)"
        android:textColor="@color/on_surface"
        android:textSize="13sp"
        android:fontFamily="sans-serif-bold"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etNotes"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/bg_white_3d_pill"
        android:hint="Any details for the doctor..."
        android:gravity="top"
        android:padding="16dp"
        android:layout_marginBottom="24dp" />

    <!-- Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">
        
        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CANCEL"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:padding="12dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btnSubmit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BOOK NOW"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_mocha_3d_pill" />
    </LinearLayout>

</LinearLayout>
