<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_invoice_card"
    android:elevation="4dp"
    android:clipToPadding="false">

    <!-- Status Left Border Color Strip -->
    <View
        android:id="@+id/statusStrip"
        android:layout_width="6dp"
        android:layout_height="match_parent"
        android:background="#00F49C" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Patient Avatar & ID + Total Amount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:baselineAligned="false">

            <!-- Avatar & ID block -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <!-- Avatar Circle -->
                <RelativeLayout
                    android:id="@+id/patientAvatarBg"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tvInitials"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PT"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-bold" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">
                    <TextView
                        android:id="@+id/tvInvoiceId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#PAY-0001"
                        android:textColor="#0B0E11"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black" />
                    <TextView
                        android:id="@+id/tvInvoiceService"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prenatal Check-up"
                        android:textColor="#6B7280"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Amount block -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">
                <TextView
                    android:id="@+id/tvInvoiceAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱0.00"
                    android:textColor="#0B0E11"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-bold"
                    android:letterSpacing="-0.03" />
                <TextView
                    android:id="@+id/tvInvoiceDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mar 26, 2026"
                    android:textColor="#A0AAB5"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E7EB"
            android:layout_marginVertical="12dp" />

        <!-- Bottom Row: Status Badge & Actions -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Status Badge -->
            <TextView
                android:id="@+id/tvInvoiceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_status_paid"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Payment Complete"
                android:textColor="#00F49C"
                android:textSize="10sp"
                android:fontFamily="sans-serif-bold" />

            <LinearLayout
                android:id="@+id/actionContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <!-- Pay Now Glow Button -->
                <TextView
                    android:id="@+id/btnPayNow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_button_glow_cyan"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="Pay Now"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"
                    android:elevation="4dp" />

                <TextView
                    android:id="@+id/btnPayDownpayment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_button_glow_pink"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="Deposit"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"
                    android:elevation="4dp" />

                <!-- Ghost Receipt Button -->
                <LinearLayout
                    android:id="@+id/btnViewReceipt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_button_ghost"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="#6B7280" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Receipt"
                        android:textColor="#6B7280"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-bold" />
                </LinearLayout>

            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
