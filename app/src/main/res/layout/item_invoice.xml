<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <!-- Date Column -->
        <TextView
            android:id="@+id/tvInvoiceDate"
            android:layout_width="0dp"
            android:layout_weight="1.8"
            android:layout_height="wrap_content"
            android:text="Mar 26"
            android:textColor="#64748B"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

        <!-- Service Column -->
        <TextView
            android:id="@+id/tvInvoiceService"
            android:layout_width="0dp"
            android:layout_weight="4"
            android:layout_height="wrap_content"
            android:text="Check-up"
            android:textColor="#0F172A"
            android:textSize="13sp"
            android:fontFamily="sans-serif-bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Amount Column -->
        <TextView
            android:id="@+id/tvInvoiceAmount"
            android:layout_width="0dp"
            android:layout_weight="2.5"
            android:layout_height="wrap_content"
            android:text="₱0.00"
            android:textColor="#0F172A"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black" />

        <!-- Status Column -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_weight="1.7"
            android:layout_height="wrap_content"
            android:gravity="end">
            <TextView
                android:id="@+id/tvInvoiceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_pill"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Paid"
                android:textColor="#059669"
                android:textSize="10sp"
                android:fontFamily="sans-serif-bold" />
            
            <!-- Hidden for compatibility -->
            <TextView android:id="@+id/btnPayNow" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/btnPayDownpayment" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/btnViewReceipt" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <View android:id="@+id/statusStrip" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/tvInitials" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/tvInvoiceId" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        </RelativeLayout>

    </LinearLayout>

    <!-- Subtle Row Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F1F5F9"
        android:layout_marginHorizontal="16dp" />

</LinearLayout>
