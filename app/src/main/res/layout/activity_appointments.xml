<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_billing_cosmic_abyss">
    
    <!-- Decorative Aura Blobs for 3D Depth -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_marginTop="-100dp"
        android:layout_marginStart="-120dp"
        android:background="@drawable/bg_aura_blob_cyan"
        android:alpha="0.2" />
        
    <View
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="100dp"
        android:layout_marginEnd="-100dp"
        android:background="@drawable/bg_aura_blob_violet"
        android:alpha="0.15" />

    <!-- ══════════════════════════════════════════ -->
    <!--  SECTION 1: APPOINTMENTS HEADER            -->
    <!-- ══════════════════════════════════════════ -->
    <RelativeLayout
        android:id="@+id/appointmentsHeader"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_glass_card_navy_premium"
        android:elevation="20dp"
        android:paddingHorizontal="20dp">


        <!-- Live Badge (Top Left Mini) -->
        <LinearLayout
            android:id="@+id/liveBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_glass_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp">
            <View
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:background="@drawable/bg_circle_red"
                android:layout_marginEnd="4dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Booking Manager: Live"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/liveBadge"
            android:layout_marginTop="2dp"
            android:text="Appointments"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvTitle"
            android:text="Manage your upcoming schedules"
            android:textColor="#BBFFD8"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:alpha="0.7" />

    </RelativeLayout>

    <!-- ══════════════════════════════════════════ -->
    <!--  MAIN SCROLLABLE CONTENT                   -->
    <!-- ══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/appointmentsHeader"
        android:layout_above="@+id/nav_area"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Spacer -->
            <View 
                android:layout_width="match_parent" 
                android:layout_height="12dp" />

            <!-- ══════════════════════════════════════════ -->
            <!--  CALENDAR METRIC CARD                      -->
            <!-- ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_glass_card_billing"
                android:elevation="6dp"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:id="@+id/calendarHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tvMonthYear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="FEBRUARY 2026"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true">
                        <ImageView android:id="@+id/btnPrevMonth" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_previous" app:tint="#6B7280" />
                        <ImageView android:id="@+id/btnNextMonth" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginStart="16dp" android:src="@android:drawable/ic_media_next" app:tint="#6B7280" />
                    </LinearLayout>
                </RelativeLayout>

                <!-- GRID -->
                <include layout="@layout/layout_appointments_calendar_grid" />

                <!-- LEGEND -->
                <View 
                    android:layout_width="match_parent" 
                    android:layout_height="1dp" 
                    android:layout_marginTop="16dp" 
                    android:background="#1AFFFFFF" />
                
                <RelativeLayout 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:layout_marginTop="12dp">
                    
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:layout_centerVertical="true"
                        android:text="• DOTS INDICATE APPOINTMENTS" 
                        android:textColor="#9CA3AF" 
                        android:textSize="9sp" 
                        android:fontFamily="sans-serif-bold" 
                        android:letterSpacing="0.05" />
                    
                    <LinearLayout 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal">
                        
                        <View android:layout_width="6dp" android:layout_height="6dp" android:layout_gravity="center" android:background="#00F49C" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="CONFIRMED" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-bold" android:alpha="0.8" />
                        <View android:layout_width="6dp" android:layout_height="6dp" android:layout_marginStart="12dp" android:layout_gravity="center" android:background="#FFBC00" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="PENDING" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-bold" android:alpha="0.8" />
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>

            <!-- ══════════════════════════════════════════ -->
            <!--  EXPRESS BOOKING CHIPS                     -->
            <!-- ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_recent_history" app:tint="#00F49C" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:fontFamily="sans-serif-black" android:text="EXPRESS BOOKING SLOTS" android:textColor="@color/white" android:textSize="13sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp">
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- CARD 1 -->
                    <RelativeLayout
                        android:id="@+id/cardExpress1"
                        android:layout_width="120dp"
                        android:layout_height="110dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_glass_card_cyan"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="4dp">
                        <TextView android:id="@+id/tvExpressDate1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="16dp" android:text="--" android:textColor="@color/white" android:fontFamily="sans-serif-black" android:textSize="18sp" />
                        <TextView android:id="@+id/tvExpressDay1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="40dp" android:text="--" android:textColor="@color/white" android:textSize="11sp" android:fontFamily="sans-serif-medium" android:alpha="0.7" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="64dp" android:gravity="center_vertical">
                            <ImageView android:layout_width="10dp" android:layout_height="10dp" android:src="@android:drawable/ic_menu_recent_history" app:tint="#00FFFF" />
                            <TextView android:id="@+id/tvExpressTime1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="--" android:textColor="#00FFFF" android:textSize="10sp" android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentBottom="true" android:layout_alignParentEnd="true" android:layout_margin="12dp" android:src="@android:drawable/ic_media_play" app:tint="#00FFFF" />
                    </RelativeLayout>

                    <!-- CARD 2 -->
                    <RelativeLayout
                        android:id="@+id/cardExpress2"
                        android:layout_width="120dp"
                        android:layout_height="110dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_glass_card_amber"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="4dp">
                        <TextView android:id="@+id/tvExpressDate2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="16dp" android:text="--" android:textColor="@color/white" android:fontFamily="sans-serif-black" android:textSize="18sp" />
                        <TextView android:id="@+id/tvExpressDay2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="40dp" android:text="--" android:textColor="@color/white" android:textSize="11sp" android:fontFamily="sans-serif-medium" android:alpha="0.7" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="64dp" android:gravity="center_vertical">
                            <ImageView android:layout_width="10dp" android:layout_height="10dp" android:src="@android:drawable/ic_menu_recent_history" app:tint="#FFCC00" />
                            <TextView android:id="@+id/tvExpressTime2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="--" android:textColor="#FFCC00" android:textSize="10sp" android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentBottom="true" android:layout_alignParentEnd="true" android:layout_margin="12dp" android:src="@android:drawable/ic_media_play" app:tint="#FFCC00" />
                    </RelativeLayout>

                    <!-- CARD 3 -->
                    <RelativeLayout
                        android:id="@+id/cardExpress3"
                        android:layout_width="120dp"
                        android:layout_height="110dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_glass_card_purple"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="4dp">
                        <TextView android:id="@+id/tvExpressDate3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="16dp" android:text="--" android:textColor="@color/white" android:fontFamily="sans-serif-black" android:textSize="18sp" />
                        <TextView android:id="@+id/tvExpressDay3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="40dp" android:text="--" android:textColor="@color/white" android:textSize="11sp" android:fontFamily="sans-serif-medium" android:alpha="0.7" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="64dp" android:gravity="center_vertical">
                            <ImageView android:layout_width="10dp" android:layout_height="10dp" android:src="@android:drawable/ic_menu_recent_history" app:tint="#FF00FF" />
                            <TextView android:id="@+id/tvExpressTime3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="--" android:textColor="#FF00FF" android:textSize="10sp" android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentBottom="true" android:layout_alignParentEnd="true" android:layout_margin="12dp" android:src="@android:drawable/ic_media_play" app:tint="#FF00FF" />
                    </RelativeLayout>

                    <!-- CARD 4 -->
                    <RelativeLayout
                        android:id="@+id/cardExpress4"
                        android:layout_width="120dp"
                        android:layout_height="110dp"
                        android:background="@drawable/bg_glass_card_emerald"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="4dp">
                        <TextView android:id="@+id/tvExpressDate4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="16dp" android:text="--" android:textColor="@color/white" android:fontFamily="sans-serif-black" android:textSize="18sp" />
                        <TextView android:id="@+id/tvExpressDay4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="40dp" android:text="--" android:textColor="@color/white" android:textSize="11sp" android:fontFamily="sans-serif-medium" android:alpha="0.7" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="64dp" android:gravity="center_vertical">
                            <ImageView android:layout_width="10dp" android:layout_height="10dp" android:src="@android:drawable/ic_menu_recent_history" app:tint="#00F49C" />
                            <TextView android:id="@+id/tvExpressTime4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="--" android:textColor="#00F49C" android:textSize="10sp" android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentBottom="true" android:layout_alignParentEnd="true" android:layout_margin="12dp" android:src="@android:drawable/ic_media_play" app:tint="#00F49C" />
                    </RelativeLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- ══════════════════════════════════════════ -->
            <!--  APPOINTMENTS LIST                         -->
            <!-- ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSelectedDateAppointments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Appointments for Today"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black" />

                <!-- PREMIUM 3D FILTERS -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:scrollbars="none"
                    android:clipToPadding="false">
                    
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <TextView
                            android:id="@+id/filterAll"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_filter_chip"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="ALL"
                            android:textColor="@color/white"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/filterPending"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_filter_chip"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="PENDING"
                            android:textColor="@color/white"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/filterConfirmed"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_filter_chip"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="CONFIRMED"
                            android:textColor="@color/white"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/filterRejected"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_filter_chip"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="REJECTED"
                            android:textColor="@color/white"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/filterCompleted"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_filter_chip"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="COMPLETED"
                            android:textColor="@color/white"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- EMPTY/LOADING STATES -->
                <LinearLayout
                    android:id="@+id/layoutLoading"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <ProgressBar android:layout_width="36dp" android:layout_height="36dp" android:indeterminateTint="#00F49C" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Syncing appointments…" android:textColor="#6B7280" android:textSize="12sp" android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_menu_today" app:tint="#D1D5DB" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="No appointments found" android:textColor="#6B7280" android:textSize="14sp" android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- MOMMY'S REMINDER (NEW) -->
                <RelativeLayout
                    android:id="@+id/layoutReminders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_glass_card_purple"
                    android:padding="20dp"
                    android:elevation="6dp">
                    
                    <ImageView
                        android:id="@+id/ivAuraIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_glass_circle"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_help"
                        app:tint="#FF3C8E" />
                        
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ivAuraIcon"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        
                        <TextView
                            android:id="@+id/tvReminderDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Recommended Next: April 12"
                            android:textColor="#FF3C8E"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-black" />
                            
                        <TextView
                            android:id="@+id/tvReminderAdvice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Your doctor suggests a follow-up ultrasound for your 24th week check-up."
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"
                            android:alpha="0.7" />
                    </LinearLayout>
                </RelativeLayout>

                <!-- THE RECYCLERVIEW -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewAppointments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FLOATING BOOK PILL -->
    <LinearLayout
        android:id="@+id/btnBookFloating"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="90dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_pro_max_button"
        android:backgroundTint="#FFFFFF"
        android:elevation="6dp"
        android:gravity="center"
        android:paddingHorizontal="24dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="+  BOOK"
            android:textColor="#059669"
            android:textSize="14sp"
            android:letterSpacing="0.2" />
    </LinearLayout>

    <!-- FIXED BOTTOM NAV (ROBUST PIN) -->
    <FrameLayout
        android:id="@+id/nav_area"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true">
        <include layout="@layout/layout_bottom_nav" />
    </FrameLayout>

</RelativeLayout>
