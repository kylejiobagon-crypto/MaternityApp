<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ✅ ULTRA-PREMIUM LAYER 0: Pure XML Deep Space Nebula -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_billing_cosmic_abyss" />

    <!-- ✅ ULTRA-PREMIUM LAYER 1: Ambient Aura Blobs -->
    <View
        android:layout_width="450dp"
        android:layout_height="450dp"
        android:layout_marginTop="-150dp"
        android:layout_marginStart="-150dp"
        android:background="@drawable/bg_aura_blob_cyan"
        android:alpha="0.2" />

    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="-100dp"
        android:layout_marginEnd="-100dp"
        android:background="@drawable/bg_aura_blob_violet"
        android:alpha="0.15" />

    <!-- ✅ MAIN CONTENT SCROLLER -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/nav_area"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="40dp">

            <!-- ✅ PREMIUM HEADER: CENTERED ICONIC HUB -->
            <LinearLayout
                android:id="@+id/profileHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card_navy_premium"
                android:elevation="14dp"
                android:padding="32dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginBottom="24dp">

                <!-- 1. LARGE CENTERED AVATAR -->
                <RelativeLayout
                    android:id="@+id/avatarContainer"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_avatar_3d_realistic_glow"
                    android:elevation="14dp"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfileAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:shapeAppearanceOverlay="@style/RoundedProfileAvatar" />

                    <!-- CAMERA HERO OVERLAY (For Upload Indicator) -->
                    <RelativeLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:layout_margin="2dp"
                        android:background="@drawable/bg_dot_emerald_glow"
                        android:elevation="10dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_centerInParent="true"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="@color/white" />
                    </RelativeLayout>
                </RelativeLayout>

                <!-- 2. NAME HUB -->
                <TextView
                    android:id="@+id/tvProfileNameHero"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Maternity Hub"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-black"
                    android:shadowColor="@color/neon_galactic_cyan"
                    android:shadowRadius="12"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Health Profile — Cloud Synced"
                    android:textColor="#BBFFD8"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-bold"
                    android:letterSpacing="0.06"
                    android:alpha="0.6"
                    android:gravity="center" />

                <!-- 3. VERIFIED STATUS -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_glass_pill"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp">
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_dot_3d"
                        android:layout_marginEnd="8dp"
                        app:tint="#00F49C" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IDENTITY FULLY VERIFIED"
                        android:textColor="@color/white"
                        android:textSize="9sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.08"
                        android:alpha="0.8" />
                </LinearLayout>

            </LinearLayout>

            <!-- ✅ STATS HUB: 3D GLASS CARDS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="28dp">

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="115dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_stat_card_aura_light_blue"
                    android:elevation="10dp"
                    android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DUE DATE" android:textColor="#E0E7FF" android:textSize="8sp" android:fontFamily="sans-serif-black" />
                    <TextView android:id="@+id/tvDueDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:text="--" android:textColor="@color/white" android:textSize="14sp" android:fontFamily="sans-serif-black" />
                    <View android:layout_width="20dp" android:layout_height="2dp" android:background="#4DFFFFFF" android:layout_alignParentBottom="true" android:layout_centerHorizontal="true" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="115dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_stat_card_aura_light_pink"
                    android:elevation="12dp"
                    android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WEEKS" android:textColor="#FEE2E2" android:textSize="8sp" android:fontFamily="sans-serif-black" />
                    <TextView android:id="@+id/tvWeeks" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:text="--" android:textColor="@color/white" android:textSize="32sp" android:fontFamily="sans-serif-black" android:shadowColor="#CCFF0092" android:shadowRadius="8" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="115dp"
                    android:background="@drawable/bg_stat_card_aura_light_violet"
                    android:elevation="10dp"
                    android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TRIMESTER" android:textColor="#F3E8FF" android:textSize="8sp" android:fontFamily="sans-serif-black" />
                    <TextView android:id="@+id/tvTrimester" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:text="--" android:textColor="@color/white" android:textSize="32sp" android:fontFamily="sans-serif-black" />
                </RelativeLayout>
            </LinearLayout>

            <!-- ✅ CORE SPECS: NEON GLASS HUB -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card_navy_premium"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="26dp"
                android:layout_marginBottom="24dp">
                
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IDENTITY PROTOCOL" android:textColor="@color/white" android:textSize="14sp" android:fontFamily="sans-serif-black" android:layout_marginBottom="24dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FIRST NAME" android:textColor="#BBFFD8" android:textSize="8sp" android:fontFamily="sans-serif-black" android:alpha="0.6" />
                        <EditText android:id="@+id/etFirstName" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_premium_input_field_glass" android:textColor="@color/white" android:textSize="14sp" android:layout_marginTop="6dp" android:paddingHorizontal="14dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LAST NAME" android:textColor="#BBFFD8" android:textSize="8sp" android:fontFamily="sans-serif-black" android:alpha="0.6" />
                        <EditText android:id="@+id/etLastName" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_premium_input_field_glass" android:textColor="@color/white" android:textSize="14sp" android:layout_marginTop="6dp" android:paddingHorizontal="14dp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="EMAIL CHANNEL" android:textColor="#BBFFD8" android:textSize="8sp" android:fontFamily="sans-serif-black" android:alpha="0.6" />
                <EditText android:id="@+id/etEmail" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_premium_input_field_glass" android:textColor="@color/white" android:textSize="14sp" android:layout_marginTop="6dp" android:paddingHorizontal="14dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="PHONE" android:textColor="#BBFFD8" android:textSize="8sp" android:fontFamily="sans-serif-black" android:alpha="0.6" />
                <EditText android:id="@+id/etPhone" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_premium_input_field_glass" android:textColor="@color/white" android:textSize="14sp" android:layout_marginTop="6dp" android:paddingHorizontal="14dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="BIRTHDATE &amp; AGE" android:textColor="#BBFFD8" android:textSize="8sp" android:fontFamily="sans-serif-black" android:alpha="0.6" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal">
                    <EditText android:id="@+id/etDob" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:background="@drawable/bg_premium_input_field_glass" android:textColor="@color/white" android:textSize="14sp" android:paddingHorizontal="14dp" />
                    <EditText android:id="@+id/etAge" android:layout_width="70dp" android:layout_height="52dp" android:layout_marginStart="10dp" android:background="@drawable/bg_premium_input_field_glass" android:textColor="@color/electric_cyan" android:textSize="15sp" android:fontFamily="sans-serif-black" android:gravity="center" android:enabled="false" />
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="PHILHEALTH REGISTRY" android:textColor="#BBFFD8" android:textSize="8sp" android:fontFamily="sans-serif-black" android:alpha="0.6" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp">
                    <EditText android:id="@+id/etPhilHealth" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_premium_input_field_glass" android:textColor="@color/white" android:textSize="14sp" android:paddingHorizontal="14dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_glass_pill"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:text="VERIFIED"
                        android:textColor="@color/white"
                        android:textSize="8sp"
                        android:elevation="2dp"
                        android:fontFamily="sans-serif-black" />
                </RelativeLayout>
            </LinearLayout>

            <!-- ✅ CLINICAL GLASS HUB -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card_navy_premium"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="26dp"
                android:layout_marginBottom="24dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CLINICAL VITALITY" android:textColor="@color/white" android:textSize="14sp" android:fontFamily="sans-serif-black" android:layout_marginBottom="18dp" />
                
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LMP (LAST PERIOD)" android:textColor="#BBFFD8" android:textSize="8sp" android:fontFamily="sans-serif-black" android:alpha="0.6" />
                <EditText android:id="@+id/etLmp" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_premium_input_field_glass" android:textColor="@color/white" android:textSize="14sp" android:layout_marginTop="6dp" android:paddingHorizontal="14dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BLOOD TYPE" android:textColor="#BBFFD8" android:textSize="8sp" android:fontFamily="sans-serif-black" android:alpha="0.6" />
                        <EditText android:id="@+id/etBlood" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_premium_input_field_glass" android:textColor="@color/electric_cyan" android:textSize="15sp" android:fontFamily="sans-serif-black" android:layout_marginTop="6dp" android:paddingHorizontal="14dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MONTHS PREG." android:textColor="#BBFFD8" android:textSize="8sp" android:fontFamily="sans-serif-black" android:alpha="0.6" />
                        <EditText android:id="@+id/etMonths" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_premium_input_field_glass" android:textColor="@color/white" android:textSize="15sp" android:fontFamily="sans-serif-black" android:layout_marginTop="6dp" android:paddingHorizontal="14dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ✅ LOCATION NODE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card_navy_premium"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="26dp"
                android:layout_marginBottom="24dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LOCATION NODE" android:textColor="@color/white" android:textSize="14sp" android:fontFamily="sans-serif-black" android:layout_marginBottom="16dp" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_premium_input_field_glass" android:paddingHorizontal="12dp">
                     <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@android:drawable/ic_menu_mylocation" android:layout_centerVertical="true" app:tint="@color/electric_cyan" />
                     <EditText android:id="@+id/etAddress" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginStart="32dp" android:background="@null" android:textColor="@color/white" android:textSize="14sp" />
                </RelativeLayout>
            </LinearLayout>

            <!-- ✅ SAFETY HUB: EMERGENCY CONTACTS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card_navy_premium"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="26dp"
                android:layout_marginBottom="24dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SAFETY HUB (EMERGENCY)" android:textColor="#FF3C8E" android:textSize="14sp" android:fontFamily="sans-serif-black" android:layout_marginBottom="18dp" />
                
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CONTACT NAME" android:textColor="#BBFFD8" android:textSize="8sp" android:fontFamily="sans-serif-black" android:alpha="0.6" />
                <EditText android:id="@+id/etEmergencyName" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_premium_input_field_glass" android:textColor="@color/white" android:textSize="14sp" android:layout_marginTop="6dp" android:paddingHorizontal="14dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RELATIONSHIP" android:textColor="#BBFFD8" android:textSize="8sp" android:fontFamily="sans-serif-black" android:alpha="0.6" />
                        <EditText android:id="@+id/etEmergencyRel" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_premium_input_field_glass" android:textColor="@color/white" android:textSize="14sp" android:layout_marginTop="6dp" android:paddingHorizontal="14dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EMERGENCY PHONE" android:textColor="#BBFFD8" android:textSize="8sp" android:fontFamily="sans-serif-black" android:alpha="0.6" />
                        <EditText android:id="@+id/etEmergencyPhone" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_premium_input_field_glass" android:textColor="@color/electric_cyan" android:textSize="14sp" android:layout_marginTop="6dp" android:paddingHorizontal="14dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ✅ ACTION SYNERGY -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                <TextView android:id="@+id/btnReset" android:layout_width="0dp" android:layout_weight="1" android:layout_height="58dp" android:layout_marginEnd="8dp" android:background="@drawable/bg_glass_card_navy_premium" android:text="SECURE RESET" android:textColor="@color/white" android:gravity="center" android:fontFamily="sans-serif-black" android:textSize="13sp" />
                <TextView android:id="@+id/btnEdit" android:layout_width="0dp" android:layout_weight="1" android:layout_height="58dp" android:layout_marginStart="8dp" android:background="@drawable/bg_stat_card_aura_light_blue" android:text="MODIFY IDENTITY" android:textColor="@color/white" android:gravity="center" android:fontFamily="sans-serif-black" android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ✅ ULTRA-PREMIUM SAVE BUTTON -->
    <RelativeLayout
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_premium_neon_btn"
        android:visibility="gone"
        android:elevation="20dp"
        android:layout_above="@+id/nav_area">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="SAVE PROFILE UPDATE"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:shadowRadius="4" />
    </RelativeLayout>

    <!-- Premium Loading State (Moved below nav_area in code flow but stays same ID) -->
    <RelativeLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone">
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_centerInParent="true"
            android:indeterminate="true"
            app:indicatorColor="@color/electric_cyan"
            app:trackThickness="6dp" />
    </RelativeLayout>

    <!-- FIXED BOTTOM NAV (ROBUST PIN) - Moved here to stay on TOP of overlay -->
    <FrameLayout
        android:id="@+id/nav_area"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true">
        <include layout="@layout/layout_bottom_nav" />
    </FrameLayout>

</RelativeLayout>

