<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pay_flagship_main">

    <!-- Ambient Aura Blobs -->
    <View
        android:layout_width="450dp"
        android:layout_height="450dp"
        android:background="@drawable/bg_aura_blob_cyan"
        android:alpha="0.25"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationX="150dp"
        android:translationY="20dp" />

    <View
        android:layout_width="450dp"
        android:layout_height="450dp"
        android:background="@drawable/bg_aura_blob_violet"
        android:alpha="0.15"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationX="-150dp"
        android:translationY="-20dp" />

    <!-- TOP HEADER: SECURE TERMINAL -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_glass_card_dark_realapp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/text_white" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnHelp"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_glass_card_dark_realapp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_help"
                app:tint="@color/text_white" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Secure Checkout"
                android:textColor="@color/text_white"
                android:textSize="36sp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:letterSpacing="-0.02"
                android:shadowColor="#8000F2FF"
                android:shadowRadius="15"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="APPOINTMENT DEPOSIT TERMINAL"
                android:textColor="@color/text_slate_400"
                android:textSize="11sp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.2"
                android:gravity="center"
                android:alpha="0.8"/>

            <!-- Main Service Card (Quick Repayment style) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_glass_card_flagship"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/icon_blue_glass">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_today"
                            app:tint="@color/text_white" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvServiceName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Normal Delivery"
                            android:textColor="@color/text_white"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-black"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">
                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/ic_dot_cyan" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="SECURE SLOT NOW"
                                android:textColor="@color/electric_cyan"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-black"
                                android:letterSpacing="0.1" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_input_dark"
                    android:padding="20dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="INITIAL DEPOSIT"
                        android:textColor="@color/text_slate_400"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:id="@+id/tvDepositAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱200.00"
                        android:textColor="@color/electric_cyan"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-black"
                        android:shadowColor="@color/electric_cyan"
                        android:shadowRadius="15"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="*This deposit will be fully credited to your billing account."
                    android:textColor="@color/text_slate_500"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Grid Items (Partners) -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true"
                android:layout_marginTop="24dp">

                <!-- G-Cash -->
                <LinearLayout
                    android:id="@+id/methodGcash"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_glass_card_dark_realapp"
                    android:padding="20dp"
                    android:alpha="0.6"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/icon_blue_glass">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_gallery"
                            android:layout_gravity="center"
                            app:tint="@color/text_white"/>
                    </FrameLayout>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="G-Cash"
                        android:textColor="@color/text_white"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>

                <!-- Maya -->
                <LinearLayout
                    android:id="@+id/methodMaya"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_glass_card_dark_realapp"
                    android:padding="20dp"
                    android:alpha="0.6"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/icon_green_glass">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_compass"
                            android:layout_gravity="center"
                            app:tint="@color/text_white"/>
                    </FrameLayout>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Maya"
                        android:textColor="@color/text_slate_300"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>
            </GridLayout>

            <!-- DYNAMIC PAYMENT DETAILS (LUMALABAS KAPAG CLICKED) -->
            <LinearLayout
                android:id="@+id/detailsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card_flagship"
                android:padding="20dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvAccountLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GCASH MERCHANT NO."
                    android:textColor="@color/text_slate_500"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <EditText
                        android:id="@+id/etAccountNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="+63 917 123 4567"
                        android:background="@drawable/bg_glass_input_dark"
                        android:padding="16dp"
                        android:textSize="18sp"
                        android:fontFamily="monospace"
                        android:textColor="@color/electric_cyan"
                        android:enabled="false"/>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_save" 
                        app:tint="@color/electric_cyan"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="16dp"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REFERENCE NUMBER"
                    android:textColor="@color/text_slate_500"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etReferenceNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Paste GCash Ref No. here"
                    android:background="@drawable/bg_glass_input_dark"
                    android:padding="16dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_slate_600"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Please send the ₱200.00 deposit to the number above and paste the Ref. No. to authorize."
                    android:textColor="@color/text_slate_400"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:alpha="0.7"/>
            </LinearLayout>

            <!-- ACTION AREA (INSIDE SCROLL NOW TO PREVENT BLOCKING) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:id="@+id/btnPayNow"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_button_ultra_3d"
                    android:backgroundTint="@color/electric_cyan">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="CONFIRM PAYMENT"
                        android:textColor="@color/deep_obsidian"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/btnLater"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Cancel &amp; Go Back"
                    android:textColor="#FF4D4D"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-black"
                    android:alpha="0.6" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
