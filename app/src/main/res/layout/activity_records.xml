<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_premium_sky_gradient"
    tools:context=".RecordsActivity">

    <!-- 1. FLOATING GLASS HEADER -->
    <RelativeLayout
        android:id="@+id/header_records"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_glass_card_white"
        android:elevation="12dp"
        android:paddingHorizontal="24dp">
        
        <ImageView
            android:id="@+id/btnBackRecords"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#1E293B"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEDICAL JOURNEY"
                android:textColor="#1E293B"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tracking your health progress"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_records"
        android:layout_above="@+id/nav_area"
        android:clipToPadding="false"
        android:paddingTop="24dp"
        android:paddingBottom="100dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- 2. LATEST VITALS HUB (HERO) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vitals_card_3d"
                android:elevation="16dp"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvVitalsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LATEST VITALS"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-black"
                    android:alpha="0.8"
                    android:letterSpacing="0.1" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvVitalsLabel"
                    android:layout_marginTop="20dp"
                    android:columnCount="2"
                    android:rowCount="2">

                    <!-- WEIGHT -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="fill_horizontal"
                        android:layout_columnWeight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Weight"
                            android:textColor="#FFFFFF"
                            android:alpha="0.7"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvLatestWeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="62.5 kg"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>

                    <!-- BP -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="fill_horizontal"
                        android:layout_columnWeight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Blood Pressure"
                            android:textColor="#FFFFFF"
                            android:alpha="0.7"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvLatestBP"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="115/75"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>

                    <!-- FHT -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="fill_horizontal"
                        android:layout_columnWeight="1"
                        android:layout_marginTop="20dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FHT (Heart Tone)"
                            android:textColor="#FFFFFF"
                            android:alpha="0.7"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvLatestFHT"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="145 bpm"
                            android:textColor="#00FBFB"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>

                    <!-- AOG -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="fill_horizontal"
                        android:layout_columnWeight="1"
                        android:layout_marginTop="20dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AOG (Weeks)"
                            android:textColor="#FFFFFF"
                            android:alpha="0.7"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvLatestAOG"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24 Weeks"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>
                </GridLayout>
            </RelativeLayout>

            <!-- 3. CHRONOLOGICAL HISTORY (MOCK DATA AURA) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:text="CHECK-UP HISTORY"
                android:textColor="#1E293B"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1" />

            <!-- Mock Item 1 -->
            <include layout="@layout/item_record" />

            <!-- Mock Item 2 -->
            <include layout="@layout/item_record" />

            <!-- Mock Item 3 -->
            <include layout="@layout/item_record" />

            <!-- Keep RV for future API binding -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewRecords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone" />

            <View android:layout_width="match_parent" android:layout_height="40dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FIXED BOTTOM NAV (STRICT PIN) -->
    <FrameLayout
        android:id="@+id/nav_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <include layout="@layout/layout_bottom_nav" />
    </FrameLayout>

</RelativeLayout>
